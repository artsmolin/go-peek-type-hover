{
  "name": "go-peek-type-hover",
  "displayName": "Go Peek Type Hover",
  "description": "Shows the full type definition of a variable right inside the hover tooltip in Go files.",
  "version": "0.0.3",
  "publisher": "artsmolin",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/artsmolin/go-peek-type-hover.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:go"
  ],
  "main": "./out/extension.js",
  "extensionDependencies": [
    "golang.go"
  ],
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.0"
  }
}
